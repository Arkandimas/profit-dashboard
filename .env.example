# Supabase — public vars (used by client-side code)
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase — server-only vars (used by API routes; never exposed to the browser)
# Use the service role key for server routes so RLS can be bypassed where needed.
# If not set, API routes fall back to the public anon key above.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
